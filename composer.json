{
    "name": "marceloeatworld/falai-php",
    "description": "PHP client for the fal.ai serverless AI platform, compatible with Laravel and native PHP",
    "keywords": ["fal-ai", "fal", "ai", "php", "image-generation", "serverless", "saloon"],
    "license": "MIT",
    "authors": [
        {
            "name": "Marcelo Pereira",
            "email": "diagngo@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.6",
        "saloonphp/saloon": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "MarceloEatWorld\\FalAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
